<script>{{{assetsJs}}}</script>

<style>{{{cssStrings}}}</style>

<div id="joplin-container-pluginAssetsContainer"></div>

<nav class="navbar" role="navigation" aria-label="main navigation">
	<div class="navbar-brand logo-container">
		<a class="navbar-item" href="{{logoUrl}}">
			<img class="logo" src="{{logoSrc}}"/><span class="logo-text">{{logoTitle}}</span>
		</a>
		{{#showFolderTree}}
		<button type="button" class="navbar-burger folder-tree-toggle" aria-label="Toggle notebook tree" aria-controls="folder-tree-sidebar" aria-expanded="false">
			<span aria-hidden="true"></span>
			<span aria-hidden="true"></span>
			<span aria-hidden="true"></span>
			<span aria-hidden="true"></span>
		</button>
		{{/showFolderTree}}
	</div>
</nav>

<div class="published-note-layout {{#showFolderTree}}with-tree{{/showFolderTree}}">
	{{#showFolderTree}}
	<nav id="folder-tree-sidebar" class="published-folder-sidebar" aria-label="Notebook navigation">
		<p class="sidebar-title">{{folderTree.rootTitle}}</p>
		<div id="folder-tree" class="folder-tree is-initializing"></div>
		<template id="folder-tree-data">{{folderTree.treeDataJson}}</template>
	</nav>
	{{/showFolderTree}}

	<div class="note-main">
		{{#note}}
		<p class="last-updated">Last updated: {{updatedDateTime}}</p>
		<h1 class="title">{{title}}</h1>
		<div class="note-body">
			{{{note.bodyHtml}}}
		</div>
		{{/note}}

		{{^note}}
		{{#emptyStateErrorMessage}}
		<div class="notification is-danger">
			{{emptyStateErrorMessage}}
		</div>
		{{/emptyStateErrorMessage}}
		{{{emptyStateHtml}}}
		{{/note}}
	</div>
</div>

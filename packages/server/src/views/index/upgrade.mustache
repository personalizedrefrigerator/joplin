<h1 class="title">Upgrade your account</h1>
<p class="subtitle">Upgrade to a {{upgradePriceName}} account to get the following benefits.</p>

<form id="upgrade_form" action="{{{postUrl}}}" method="POST">
	{{{csrfTag}}}
	<input type="hidden" value="{{upgradePrice.accountType}}" name="to_plan"/>

	<table class="table is-hoverable user-props-table">
		<tbody>
			<tr>
				<th class="basic-plan">{{currentPriceName}} - {{currentPrice.formattedMonthlyAmount}} / month</th>
				<th>{{upgradePriceName}} - {{upgradePrice.formattedMonthlyAmount}} / month</th>
			</tr>

			{{#showYearlyPrices}}
			<tr>
				<td>{{currentPrice.formattedAmount}} / year</td><td>{{upgradePrice.formattedAmount}} / year</td>
			</tr>
			{{/showYearlyPrices}}

			{{#planRows}}
				<tr>
					<td class="basic-plan">
						{{currentLabel}}
					</td>
					<td>
						{{upgradeLabel}}
					</td>
				</tr>
			{{/planRows}}

			<tr>
				<td style="opacity:0.7;" colspan="2">For the complete feature list, please see the <a target="_blank" href="https://joplinapp.org/plans">Plan page</a></td>
			</tr>

			<tr>
				<td></td>
				<td><input type="submit" id="upgrade_button" name="upgrade_button" class="button is-success" value="Upgrade to {{upgradePriceName}}" /></td>
			</tr>
		</tbody>
	</table>
</form>

<input type="hidden" value="{{upgradePriceName}}" id="upgrade_price_name"/>
<script>
$(() => {
	$('#upgrade_form').submit((event) => {
		const toPlanName = $('#upgrade_price_name').val();
		const ok = confirm(`Your account is going to be upgraded to ${toPlanName}. Do you wish to continue?`);
		if (!ok) event.preventDefault();
	});
});
</script>
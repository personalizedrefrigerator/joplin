# Fixes TypeScript v6 compatibility:
# - Remove "type": "module" since Joplin still uses CommonJS. Using "module" would result
#   in duplicate CodeMirror types.
# - Add "types" to the "exports" field.
diff --git a/package.json b/package.json
index 8df2d8237a170a03ef7da2db83781fcbdc7b2072..75b7bfc9248d8eb9ba6ce82e7ef2ec68eb17d9ea 100644
--- a/package.json
+++ b/package.json
@@ -15,11 +15,11 @@
     "editor",
     "code"
   ],
-  "type": "module",
   "main": "dist/index.cjs",
   "exports": {
     "import": "./dist/index.js",
-    "require": "./dist/index.cjs"
+    "require": "./dist/index.cjs",
+    "types": "./dist/index.d.ts"
   },
   "types": "dist/index.d.ts",
   "module": "dist/index.js",
